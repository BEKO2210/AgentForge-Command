# Runtime locks + state created by the scripts — never commit these
.team/locks/*
!.team/locks/.gitkeep
.team/log/events.log
.team/state/
.team/backups/
.team/snapshots/
.team/metrics.md

# Arena UI persistence (runtime state, not source of truth)
.team/arena.json

# Rust build artefacts for the optional forge-pulse sidecar
tools/*/target/
tools/*/Cargo.lock

# Node modules in the GUI server
gui/node_modules/

# OS / editor noise
.DS_Store
Thumbs.db
