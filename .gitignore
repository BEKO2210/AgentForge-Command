# Runtime locks + state created by the scripts — never commit these
.team/locks/*
!.team/locks/.gitkeep
.team/log/events.log
.team/state/
.team/backups/
.team/snapshots/
.team/metrics.md

# Arena UI persistence (runtime state, not source of truth)
.team/arena.json

# Rust build artefacts for the optional forge-pulse sidecar
tools/*/target/
tools/*/Cargo.lock

# Node modules (root workspace + per-package)
/node_modules/
gui/node_modules/
mcp/node_modules/

# Coverage artefacts (c8 / node --experimental-test-coverage) — see docs/BASELINE.md
coverage/
.nyc_output/

# OS / editor noise
.DS_Store
Thumbs.db
