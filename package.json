{
  "name": "agentforge-command",
  "version": "1.0.0",
  "description": "A premium local mission-control cockpit for orchestrating Claude Code agents.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "gui",
    "mcp"
  ],
  "bin": {
    "agentforge-command": "bin/agentforge.mjs",
    "agentforge": "bin/agentforge.mjs"
  },
  "scripts": {
    "start": "node gui/server.js",
    "dev": "node gui/server.js",
    "test": "bash tests/run.sh",
    "test:security": "node tests/security-suite.mjs",
    "test:perf": "node tests/perf-bench.mjs",
    "test:e2e": "playwright test",
    "coverage": "c8 --config .c8rc.json bash tests/run.sh",
    "gate": "bash scripts/team-check.sh",
    "audit": "npm audit --workspaces --omit=dev --audit-level=high"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.0",
    "c8": "^10.1.0"
  }
}
